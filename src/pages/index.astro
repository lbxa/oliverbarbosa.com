          </h2>
        </div>
        <div class="contact-links">
          <a href="mailto:Oliver.Chu.Barbosa@gmail.com"
            >Oliver.Chu.Barbosa@gmail.com</a
          >
          <a href="tel:+61401292798">0401 292 798</a>
          <a href="https://www.linkedin.com/in/chubarbosao"
            >linkedin.com/in/chubarbosao</a
          >
          <span>Sydney, Australia</span>
        </div>
      </section>
    </main>

    <div
      class="lightbox"
      id="lightbox"
      aria-hidden="true"
      role="dialog"
      aria-label="Expanded project image"
    >
      <button
        class="lightbox-close"
        type="button"
        aria-label="Close expanded image">&times;</button
      >
      <div class="lightbox-content">
        <img class="lightbox-image" src="" alt="" />
        <img class="lightbox-legend" src="" alt="" />
      </div>
    </div>

    <script is:inline src="/script.js"></script>
  </body>
</html>
